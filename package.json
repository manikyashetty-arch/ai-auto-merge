{
  "name": "ai-auto-merge",
  "version": "1.0.0",
  "description": "AI-powered GitHub App that auto-resolves merge conflicts in open PRs using Claude — with slash commands, a live dashboard, and Prometheus metrics",
  "private": true,
  "license": "MIT",
  "author": "Manikya Rathna",
  "main": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ArsenalAI-Official/ai-auto-merge.git"
  },
  "bugs": {
    "url": "https://github.com/ArsenalAI-Official/ai-auto-merge/issues"
  },
  "homepage": "https://github.com/ArsenalAI-Official/ai-auto-merge#readme",
  "keywords": [
    "github-app",
    "merge-conflicts",
    "claude",
    "anthropic",
    "ai",
    "automation",
    "pull-requests",
    "devops",
    "webhook"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "lint": "eslint src tests",
    "test": "jest --forceExit",
    "e2e:local": "npm run build && node scripts/e2e-local.mjs",
    "e2e:integration": "npm run build && node scripts/e2e-integration.cjs",
    "e2e:openai": "npm run build && node scripts/e2e-openai.cjs",
    "e2e:live": "npm run build && node scripts/e2e-live.cjs"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "setupFiles": [
      "<rootDir>/tests/setup.ts"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@octokit/app": "^16.1.2",
    "@octokit/rest": "^22.0.1",
    "@octokit/webhooks": "^14.2.0",
    "bullmq": "^5.76.7",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "js-yaml": "^4.1.1",
    "minimatch": "^10.2.5",
    "prettier": "^3.8.4",
    "simple-git": "^3.27.0",
    "tmp-promise": "^3.0.3",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.0.1",
    "@types/supertest": "^7.2.0",
    "@types/tmp": "^0.2.6",
    "eslint": "^10.5.0",
    "jest": "^30.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0"
  }
}
